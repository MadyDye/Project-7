#ifndef PRIORITYQUEUE_H
#define PRIORITYQUEUE_H

#include "Event.h"

struct Node {
    Event data;
    Node* next;
};

class PriorityQueue {
private:
    Node* head;

public:
    PriorityQueue() : head(nullptr) {}

    bool isEmpty() const {
        return head == nullptr;
    }

    void enqueue(const Event& newEvent) {
        Node* newNode = new Node{newEvent, nullptr};

        if (!head || newEvent > head->data) {
            newNode->next = head;
            head = newNode;
        } else {
            Node* cur = head;
            while (cur->next && !(newEvent > cur->next->data)) {
                cur = cur->next;
            }
            newNode->next = cur->next;
            cur->next = newNode;
        }
    }

    void dequeue() {
        if (!isEmpty()) {
            Node* temp = head;
            head = head->next;
            delete temp;
        }
    }

    Event peek() const {
        return head->data;
    }
};

#endif
